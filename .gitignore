# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Node (previewer, if a build step is added later)
node_modules/

# Solver outputs (layouts, previews, schematics) - not source
out/
*.litematic
*.schematic

# Generated datasets are local-only and version-namespaced (data/<version>/{multiblocks,textures}/):
# regenerated on demand, never committed, so a user can hold several pack versions side by side.
# Only the small curated fixtures below ship (tests + out-of-box example previews). See
# docs/dataset-extraction/plan.md.
/data/*
!/data/multiblocks/
!/data/textures/
/data/multiblocks/*
!/data/multiblocks/_meta.json
!/data/multiblocks/gregtech_machine_1000.json
!/data/multiblocks/gregtech_machine_1001.json
/data/textures/*
!/data/textures/manifest.json

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
